  }
`,rh`
  *[_type == "food"] | order(order asc) {
    _id,
    _createdAt,
    name,
    "slug": slug.current,
    description,
    basePrice,
    images,
    preparationTime,
    spiceLevel,
    available,
    featured,
    order,
    enableAllSizes,
    averageRating,
    totalReviews,
    category->{
      _id,
      name,
      "slug": slug.current,
      description,
      image,
      order,
      isActive
    },
    varieties[]->{
      _id,
      name,
      description,
      order
    },
    sizes[]{
      size->{
        _id,
        name,
        code,
        description,
        serveSize,
        order
      }
    },
    ingredients[]->{
      _id,
      name,
      description,
      order
    }
  }
`,rh`
