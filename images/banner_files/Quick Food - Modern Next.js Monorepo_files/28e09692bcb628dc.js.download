    isDefault
  }
`,rh`
  count(*[_type == "order" && userEmail == $email])
`,rh`
  count(*[_type == "order" && userEmail == $email && status->value.current == "delivered"])
`,rh`
  *[_type == "order" && userEmail == $email && status->value.current == "delivered"] {
    total
  }
`,rh`
  {
    "totalOrders": count(*[_type == "order"]),
    "pendingOrders": count(*[_type == "order" && status == "pending"]),
    "totalUsers": count(*[_type == "user"]),
    "totalProducts": count(*[_type == "food"]),
    "recentOrders": *[_type == "order"] | order(_createdAt desc)[0...5] {
      _id,
      orderNumber,
      userName,
      total,
      status,
      _createdAt
    },
    "paidOrders": *[_type == "order" && paymentStatus == "paid"] {
      total
    }
  }
`,rh`
  *[_type == "order"] | order(_createdAt desc) {
    _id,
    orderNumber,
    userName,
    userEmail,
    items,
    subtotal,
    deliveryFee,
    tax,
    total,
    status,
    paymentMethod,
    paymentStatus,
    deliveryAddress,
    _createdAt
  }
`,rh`
  *[_type == "user"] | order(_createdAt desc) {
    _id,
    name,
    email,
    image,
    provider,
    "role": role->name,
    "roleSlug": role->slug.current,
    _createdAt
  }
